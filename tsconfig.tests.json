{
  "compilerOptions": {
    "composite": true,
    "strict": true,
    "types": ["node"],
    "lib": ["dom", "esnext"],
    "target": "esnext",
    "module": "esnext",
    "moduleResolution": "bundler",
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "preact-sigma": ["./src/index.ts"],
      "preact-sigma/persist": ["./src/persist.ts"]
    },
    "allowImportingTsExtensions": true,
    "emitDeclarationOnly": true,
    "rootDir": "."
  },
  "include": ["tests", "src"]
}
